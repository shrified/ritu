<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8F9"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- ── TOP BAR ── -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/tag_bg"
                android:padding="10dp"
                android:src="@drawable/ic_next_arrow"
                android:scaleX="-1"
                app:tint="#993556"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/screenTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/app_font_bold"
                android:text="@string/pain_sos_title"
                android:textColor="#1A1A2E"
                android:textSize="20sp"
                app:layout_constraintStart_toEndOf="@id/backBtn"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/backBtn"
                app:layout_constraintBottom_toBottomOf="@id/backBtn" />

            <!-- ── SUBTITLE ── -->
            <TextView
                android:id="@+id/subtitleTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/app_font"
                android:text="@string/pain_sos_subtitle"
                android:textColor="#993556"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/backBtn"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ── PAIN LEVEL SELECTOR CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/selectorCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0E6EA"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/subtitleTv"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:weightSum="3">

                    <!-- Mild -->
                    <LinearLayout
                        android:id="@+id/mildBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/pain_level_selected_bg"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/mildEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😐"
                            android:textSize="26sp" />

                        <TextView
                            android:id="@+id/mildLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/app_font_bold"
                            android:text="@string/pain_level_mild"
                            android:textColor="#4B1528"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Moderate -->
                    <LinearLayout
                        android:id="@+id/moderateBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/pain_level_unselected_bg"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp">

                        <TextView
                            android:id="@+id/moderateEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😣"
                            android:textSize="26sp" />

                        <TextView
                            android:id="@+id/moderateLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/app_font_bold"
                            android:text="@string/pain_level_moderate"
                            android:textColor="#993556"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                    <!-- Severe -->
                    <LinearLayout
                        android:id="@+id/severeBtn"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@drawable/pain_level_unselected_bg"
                        android:layout_marginStart="4dp">

                        <TextView
                            android:id="@+id/severeEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="😖"
                            android:textSize="26sp" />

                        <TextView
                            android:id="@+id/severeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:fontFamily="@font/app_font_bold"
                            android:text="@string/pain_level_severe"
                            android:textColor="#993556"
                            android:textSize="11sp"
                            android:gravity="center" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── REMEDIES CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/remediesCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0E6EA"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/selectorCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/remediesHeading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/app_font_bold"
                        android:text="@string/remedies_heading"
                        android:textColor="#1A1A2E"
                        android:textSize="15sp" />

                    <!-- Remedy items injected here dynamically -->
                    <LinearLayout
                        android:id="@+id/remediesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── WARNING CARD (severe only) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/warningCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF3F3"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#FFCDD2"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/remediesCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="top">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginTop="1dp"
                        android:src="@drawable/ic_feedback"
                        app:tint="#C62828" />

                    <TextView
                        android:id="@+id/warningTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/app_font"
                        android:text="@string/see_doctor_warning"
                        android:textColor="#B71C1C"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>