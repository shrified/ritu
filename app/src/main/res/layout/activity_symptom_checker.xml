<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8F9"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- ── TOP BAR ── -->
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/tag_bg"
                android:padding="10dp"
                android:src="@drawable/ic_next_arrow"
                android:scaleX="-1"
                app:tint="#993556"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/screenTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="16dp"
                android:fontFamily="@font/app_font_bold"
                android:text="@string/symptom_checker_title"
                android:textColor="#1A1A2E"
                android:textSize="20sp"
                app:layout_constraintStart_toEndOf="@id/backBtn"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/backBtn"
                app:layout_constraintBottom_toBottomOf="@id/backBtn" />

            <!-- ── STEP INDICATOR ── -->
            <LinearLayout
                android:id="@+id/stepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@id/backBtn">

                <View
                    android:id="@+id/dot1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/legend_dot"
                    android:backgroundTint="#D4537E" />

                <View
                    android:layout_width="28dp"
                    android:layout_height="2dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="#F0E6EA" />

                <View
                    android:id="@+id/dot2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/legend_dot"
                    android:backgroundTint="#F0E6EA" />

                <View
                    android:layout_width="28dp"
                    android:layout_height="2dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:background="#F0E6EA" />

                <View
                    android:id="@+id/dot3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/legend_dot"
                    android:backgroundTint="#F0E6EA" />

            </LinearLayout>

            <!-- ── STEP HEADING ── -->
            <TextView
                android:id="@+id/stepHeading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/app_font_bold"
                android:text="@string/step1_heading"
                android:textColor="#1A1A2E"
                android:textSize="17sp"
                app:layout_constraintTop_toBottomOf="@id/stepIndicator"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/stepSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/app_font"
                android:textColor="#993556"
                android:textSize="13sp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/stepHeading"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ── CHIPS CONTAINER (Steps 1 and 2) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/chipsCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0E6EA"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/stepSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    app:chipSpacingVertical="8dp"
                    app:chipSpacingHorizontal="8dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ── RESULT CARD (Step 3) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0E6EA"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/stepSubtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Description -->
                    <TextView
                        android:id="@+id/resultDescriptionTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/app_font"
                        android:textColor="#4B1528"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.5"
                        android:paddingBottom="16dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0E6EA"
                        android:layout_marginBottom="16dp" />

                    <!-- Causes heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/app_font_bold"
                        android:text="@string/causes_heading"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:paddingBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/causesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="16dp" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0E6EA"
                        android:layout_marginBottom="16dp" />

                    <!-- Remedies heading -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/app_font_bold"
                        android:text="@string/remedies_at_home"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        android:paddingBottom="10dp" />

                    <LinearLayout
                        android:id="@+id/resultRemediesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── SEE DOCTOR CARD (Step 3 only) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/seeDoctorCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF3F3"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#FFCDD2"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/resultCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/app_font_bold"
                        android:text="@string/see_doctor_heading"
                        android:textColor="#B71C1C"
                        android:textSize="13sp"
                        android:paddingBottom="8dp" />

                    <TextView
                        android:id="@+id/seeDoctorTv"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/app_font"
                        android:textColor="#B71C1C"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ACTION BUTTON ── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/actionBtn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/app_font_bold"
                android:text="@string/btn_next"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                app:backgroundTint="@null"
                android:backgroundTint="@color/theme9"
                app:cornerRadius="24dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/seeDoctorCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>