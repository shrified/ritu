<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFF8F9"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- ── TOP BAR ── -->
            <TextView
                android:id="@+id/appTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/app_font_bold"
                android:text="@string/app_name"
                android:textColor="#1A1A2E"
                android:textSize="26sp"
                android:letterSpacing="0.01"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- ── CALENDAR CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/calendarCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0E6EA"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/appTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="16dp">

                    <TextView
                        android:id="@+id/topCurrentDateTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/app_font_bold"
                        android:textColor="#1A1A2E"
                        android:textSize="16sp"
                        android:letterSpacing="0.01"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        tools:text="April 2026" />

                    <com.kizitonwose.calendar.view.CalendarView
                        android:id="@+id/calendarView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        app:cv_dayViewResource="@layout/calendar_day_layout"
                        app:layout_constraintTop_toBottomOf="@id/topCurrentDateTv" />

                    <!-- Legend row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="12dp"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/calendarView">

                        <!-- Period legend dot -->
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/legend_dot"
                            android:backgroundTint="#D4537E"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="Period"
                            android:textSize="11sp"
                            android:textColor="#993556"
                            android:fontFamily="@font/app_font"
                            android:layout_marginEnd="14dp" />

                        <!-- Fertile legend dot -->
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/legend_dot"
                            android:backgroundTint="#1D9E75"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="Fertile"
                            android:textSize="11sp"
                            android:textColor="#0F6E56"
                            android:fontFamily="@font/app_font"
                            android:layout_marginEnd="14dp" />

                        <!-- Ovulation legend dot -->
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/legend_dot"
                            android:backgroundTint="#7F77DD"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="Ovulation"
                            android:textSize="11sp"
                            android:textColor="#534AB7"
                            android:fontFamily="@font/app_font"
                            android:layout_marginEnd="14dp" />

                        <!-- Safe legend dot -->
                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_gravity="center_vertical"
                            android:background="@drawable/legend_dot"
                            android:backgroundTint="#378ADD"
                            android:layout_marginEnd="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:text="Safe"
                            android:textSize="11sp"
                            android:textColor="#185FA5"
                            android:fontFamily="@font/app_font" />

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── STATUS / BANNER CARD (replaces old bannerLayout + conditionImg + conditionTv) ── -->
            <!--
                bannerLayout  → ImageView kept as full bleed background, same ID
                conditionImg  → centred icon on top of the tinted surface
                conditionTv   → label below icon
                editPeriodBtn → MaterialButton, same ID
            -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F5F0FB"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/calendarCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <!--
                        bannerLayout: kept as ImageView with same ID.
                        It sits behind everything (z-order = first child).
                        Kotlin sets the src via appTheme.bgImg — still works.
                        We make it fill the card and semi-transparent so the
                        pink background shows through nicely.
                    -->
                    <ImageView
                        android:id="@+id/bannerLayout"
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:scaleType="centerCrop"
                        android:alpha="0.08"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:src="@color/app_secondary_color" />

                    <!-- Cycle phase label -->
                    <TextView
                        android:id="@+id/cyclePhaseLabelTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cycle day 14"
                        android:textSize="12sp"
                        android:textColor="#993556"
                        android:fontFamily="@font/app_font_bold"
                        android:letterSpacing="0.04"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent" />

                    <!-- conditionImg: large icon, same ID -->
                    <ImageView
                        android:id="@+id/conditionImg"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginTop="10dp"
                        app:layout_constraintTop_toBottomOf="@id/cyclePhaseLabelTv"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:src="@drawable/high_chances" />

                    <!-- conditionTv: same ID, now larger & left-aligned -->
                    <TextView
                        android:id="@+id/conditionTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:fontFamily="@font/app_font_bold"
                        android:textColor="#4B1528"
                        android:textSize="20sp"
                        android:lineSpacingMultiplier="1.1"
                        app:layout_constraintTop_toTopOf="@id/conditionImg"
                        app:layout_constraintStart_toEndOf="@id/conditionImg"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:text="Fertile window" />

                    <TextView
                        android:id="@+id/chancestv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/app_font"
                        android:text="@string/chances_of_pregnancy"
                        android:textColor="#993556"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/conditionTv"
                        app:layout_constraintStart_toEndOf="@id/conditionImg"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Divider -->
                    <View
                        android:id="@+id/statusDivider"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="18dp"
                        android:background="#F0D0DA"
                        app:layout_constraintTop_toBottomOf="@id/conditionImg"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Next period chip row -->
                    <TextView
                        android:id="@+id/nextPeriodLabelTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Next period"
                        android:textSize="12sp"
                        android:textColor="#993556"
                        android:fontFamily="@font/app_font"
                        app:layout_constraintTop_toBottomOf="@id/statusDivider"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/nextPeriodCountTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="in 14 days"
                        android:textSize="13sp"
                        android:textColor="#4B1528"
                        android:fontFamily="@font/app_font_bold"
                        app:layout_constraintTop_toBottomOf="@id/statusDivider"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- editPeriodBtn: same ID, restyled -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/editPeriodBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/app_font_bold"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:text="@string/edit_period"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        android:backgroundTint="@color/theme9"
                        app:backgroundTint="@null"
                        app:strokeColor="#fff"
                        app:strokeWidth="1dp"
                        android:textColor="#fff"
                        app:cornerRadius="22dp"
                        app:iconTint="#993556"
                        app:layout_constraintTop_toBottomOf="@id/nextPeriodLabelTv"
                        app:layout_constraintStart_toStartOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── OVULATION / FERTILE / SAFE DATA CARDS ── -->
            <!-- homeRecyclerView: same ID, used by HomeRecyclerAdapter -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/homeRecyclerView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layout_constraintTop_toBottomOf="@id/statusCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- ── LOG SYMPTOMS / NOTES CARD (notesTv MaterialCardView, same ID) ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/notesTv"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0E6EA"
                app:strokeWidth="1dp"
                app:layout_constraintTop_toBottomOf="@id/homeRecyclerView"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Icon chip -->
                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/addIcon"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_add_dotted"
                        android:background="@drawable/tag_bg"
                        android:padding="10dp"
                        app:tint="@color/app_primary_color"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <TextView
                        android:id="@+id/logTitleTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/app_font_bold"
                        android:text="@string/log_your_symptoms"
                        android:textColor="#1A1A2E"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/addIcon"
                        app:layout_constraintEnd_toStartOf="@id/chevronIcon"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toTopOf="@id/logSubtitleTv" />

                    <TextView
                        android:id="@+id/logSubtitleTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:fontFamily="@font/app_font"
                        android:text="Track mood, flow &amp; more"
                        android:textColor="#993556"
                        android:textSize="12sp"
                        app:layout_constraintStart_toEndOf="@id/addIcon"
                        app:layout_constraintEnd_toStartOf="@id/chevronIcon"
                        app:layout_constraintTop_toBottomOf="@id/logTitleTv"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/chevronIcon"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_next_arrow"
                        app:tint="#C4A0B0"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/irregularityCard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FFF8E1"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/statusCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_feedback"
                        app:tint="#F57F17" />

                    <TextView
                        android:id="@+id/irregularityTv"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/app_font"
                        android:textColor="#5D4037"
                        android:textSize="13sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── ARTICLES SECTION ── -->
            <TextView
                android:id="@+id/forYouTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/app_font_bold"
                android:text="@string/recommended"
                android:textColor="#1A1A2E"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/notesTv" />

            <!-- articlesRecycler: same ID, FeaturedBlogAdapter attached by Kotlin -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/articlesRecycler"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"
                app:layout_constraintTop_toBottomOf="@id/forYouTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</layout>